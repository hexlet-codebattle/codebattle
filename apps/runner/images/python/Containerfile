ARG RUNNER_IMAGE=ghcr.io/hexlet-codebattle/runner-zig:latest
ARG PY_TAG=3.14.5-alpine3.23
ARG TARGETPLATFORM

FROM --platform=$TARGETPLATFORM ${RUNNER_IMAGE} AS runner
FROM --platform=$TARGETPLATFORM python:${PY_TAG}

RUN apk add --no-cache make

  # Match the runner's slot UID (RUN_UID_BASE+slot, default 10001+slot). Real
  # HOME = /home/app rather than /nonexistent so any tool that writes under
  # $HOME has somewhere to go.
RUN addgroup -S app -g 10001 \
  && adduser -S -D -h /home/app -s /sbin/nologin -G app -u 10001 app

WORKDIR /usr/src/app
RUN chown app:app /usr/src/app

COPY --chown=app:app check ./check
COPY --chown=app:app checker.py .
COPY --chown=app:app Makefile .

USER app

EXPOSE 4040
COPY --from=runner /app/codebattle_runner /runner/codebattle_runner
ENTRYPOINT ["/runner/codebattle_runner"]
