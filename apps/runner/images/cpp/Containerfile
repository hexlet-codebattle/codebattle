ARG RUNNER_IMAGE=ghcr.io/hexlet-codebattle/runner-zig:latest
ARG ALPINE_TAG=3.23
ARG TARGETPLATFORM

########################################
# 1) builder – PCH + prebuilt runtime.o
########################################
FROM --platform=$TARGETPLATFORM alpine:${ALPINE_TAG} AS pch-builder
RUN apk add --no-cache clang mold lld libc++ make

# Compiler flags must match the per-run flags in Makefile, otherwise clang
# rejects the PCH / object file as incompatible.
ENV CB_FLAGS="-std=c++23 -O0 -g0 -pipe -fno-stack-protector -fno-pic -fno-asynchronous-unwind-tables -w"

COPY prelude.hpp /pch/all.hpp
RUN clang++ ${CB_FLAGS} -x c++-header /pch/all.hpp -o /pch/all.pch

COPY runtime.cpp /pch/runtime.cpp
RUN clang++ ${CB_FLAGS} -include-pch /pch/all.pch \
      -c /pch/runtime.cpp -o /pch/runtime.o

########################################
# 2) runner stage
########################################
FROM --platform=$TARGETPLATFORM ${RUNNER_IMAGE} AS runner

########################################
# 3) runtime – super-light layer
########################################
FROM --platform=$TARGETPLATFORM alpine:${ALPINE_TAG}

RUN apk add --no-cache clang mold lld libc++ make

# idempotent user/group creation (no failure if already present)
RUN grep -q '^app:' /etc/group || addgroup -S -g 10001 app \
  && id -u app >/dev/null 2>&1 || adduser -S -D -H -h /nonexistent -s /sbin/nologin -G app -u 10001 app

# working dir for mounted code
WORKDIR /usr/src/app

# precompiled artifacts (kept the .hpp around for debugging)
COPY --from=pch-builder /pch/all.pch    /pch/all.pch
COPY --from=pch-builder /pch/all.hpp    /pch/all.hpp
COPY --from=pch-builder /pch/runtime.o  /pch/runtime.o

# app files
COPY check ./check
COPY Makefile ./

# don’t fail if user/group already exists; chown only if it does
RUN chown -R app:app /usr/src/app || true

EXPOSE 4040
COPY --from=runner /app/codebattle_runner /runner/codebattle_runner
ENTRYPOINT ["/runner/codebattle_runner"]
